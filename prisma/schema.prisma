generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int    @id @default(autoincrement())
  email String? @unique
  passwordHash String?
  files File[]
}

model File {
  id  Int @id @default(autoincrement())
  // data entered by the user on the form //
  fileName String

  //  data from the file itself //
  fieldName String //name specified in the form
  originalName  String
  encoding  String
  mimetype  String
  size  Int?  //size of file in bytes
  destination String //folder to which the file has been saved
  path  String  //full path to uploaded file
  uplaodedAt  DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user  User  @relation(fields: [userId], references: [id])
  userId  Int
}